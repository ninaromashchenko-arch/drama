import React, { useState } from 'react';
import { 
  CheckCircle, 
  AlertCircle, 
  Copy, 
  Loader2, 
  RefreshCcw,
  Layers,
  MapPin,
  UserCheck,
  Globe,
  Type
} from 'lucide-react';

/**
 * Constants & Configuration
 */
const API_MODEL = "gemini-2.5-flash-preview-09-2025";

const MARKETS = [
  { id: 'kenya', name: 'Kenya', flag: '🇰🇪' },
  { id: 'nigeria', name: 'Nigeria', flag: '🇳🇬' },
  { id: 'philippines', name: 'Philippines', flag: '🇵🇭' },
  { id: 'south_africa', name: 'South Africa', flag: '🇿🇦' }
];

/**
 * Utility: Exponential Backoff for API Calls
 */
const callGeminiWithRetry = async (userPrompt, systemPrompt, retries = 0) => {
  const apiKey = ""; 
  const delay = Math.pow(2, retries) * 1000;

  try {
    const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/${API_MODEL}:generateContent?key=${apiKey}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        contents: [{ parts: [{ text: userPrompt }] }],
        systemInstruction: { parts: [{ text: systemPrompt }] }
      })
    });

    if (!response.ok) {
      if (response.status === 429 && retries < 5) {
        await new Promise(res => setTimeout(res, delay));
        return callGeminiWithRetry(userPrompt, systemPrompt, retries + 1);
      }
      throw new Error(`API Error: ${response.statusText}`);
    }

    const data = await response.json();
    const text = data.candidates?.[0]?.content?.parts?.[0]?.text;
    if (!text) throw new Error("Empty response from model");
    return text;
  } catch (err) {
    if (retries < 5) {
      await new Promise(res => setTimeout(res, delay));
      return callGeminiWithRetry(userPrompt, systemPrompt, retries + 1);
    }
    throw err;
  }
};

const App = () => {
  const [marketStories, setMarketStories] = useState({
    kenya: '',
    nigeria: '',
    philippines: '',
    south_africa: ''
  });
  const [masterLead, setMasterLead] = useState('');
  const [results, setResults] = useState({});
  const [loading, setLoading] = useState({});
  const [error, setError] = useState(null);
  const [successMsg, setSuccessMsg] = useState(null);

  const handleStoryChange = (marketId, value) => {
    setMarketStories(prev => ({ ...prev, [marketId]: value }));
  };

  const applyToMarkets = async () => {
    if (!masterLead.trim()) {
      setError("Please write or paste a Master Lead first.");
      return;
    }
    
    const activeMarkets = MARKETS.filter(m => marketStories[m.id].trim().length > 0);
    if (activeMarkets.length === 0) {
      setError("Please provide story text for at least one market.");
      return;
    }

    activeMarkets.forEach(async (m) => {
      setLoading(prev => ({ ...prev, [m.id]: true }));
      try {
        const localPrompt = `Take this MASTER LEAD and swap bracketed placeholders with specific names/details from the STORY SOURCE for ${m.name}.
        
        REQUIRED SWAPS:
        - [MY_NAME], [PARTNER_NAME], [CITY], [CURRENCY]
        
        STORY SOURCE:
        ${marketStories[m.id].substring(0, 12000)}

        MASTER LEAD:
        ${masterLead}`;
        
        const systemPrompt = `Extract entities and replace placeholders. Maintain 1st person tone. No markdown bolding. Output ONLY the localized text.`;
        
        const localResult = await callGeminiWithRetry(localPrompt, systemPrompt);
        setResults(prev => ({ ...prev, [m.id]: localResult }));
      } catch (err) {
        setError(`Error (${m.name}): ${err.message}`);
      } finally {
        setLoading(prev => ({ ...prev, [m.id]: false }));
      }
    });
  };

  const copyToClipboard = (text) => {
    const textArea = document.createElement("textarea");
    textArea.value = text;
    document.body.appendChild(textArea);
    textArea.select();
    try {
      document.execCommand('copy');
      setSuccessMsg("Copied!");
      setTimeout(() => setSuccessMsg(null), 2000);
    } catch (err) { console.error(err); }
    document.body.removeChild(textArea);
  };

  return (
    <div className="min-h-screen bg-[#F8FAFC] text-slate-900 font-sans selection:bg-indigo-100">
      <header className="sticky top-0 z-40 bg-white/80 backdrop-blur-md border-b border-slate-200">
        <div className="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <div className="w-10 h-10 bg-indigo-600 rounded-lg flex items-center justify-center text-white shadow-lg shadow-indigo-200">
              <UserCheck size={20} />
            </div>
            <div>
              <h1 className="text-lg font-black tracking-tight text-slate-900 uppercase">Lead Localizer</h1>
            </div>
          </div>
          <button 
            onClick={applyToMarkets}
            disabled={!masterLead.trim() || Object.values(loading).some(v => v === true)}
            className="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2 rounded-lg font-bold text-sm shadow-lg transition-all active:scale-95 disabled:opacity-50"
          >
            <RefreshCcw className={`w-3.5 h-3.5 ${Object.values(loading).some(v => v === true) ? 'animate-spin' : ''}`} />
            Localize All
          </button>
        </div>
      </header>

      <main className="max-w-7xl mx-auto p-4 md:p-6 grid grid-cols-1 lg:grid-cols-12 gap-6">
        {/* Left Column */}
        <div className="lg:col-span-4 space-y-6">
          <section className="bg-white p-5 rounded-2xl border border-slate-200 h-[calc(100vh-8rem)] flex flex-col overflow-hidden sticky top-20">
            <div className="flex items-center justify-between mb-4">
              <h2 className="text-[10px] font-black text-slate-400 uppercase tracking-widest">Market Stories</h2>
              <Type size={12} className="text-slate-300" />
            </div>
            <div className="flex-1 overflow-y-auto pr-1 space-y-3 custom-scrollbar">
              {MARKETS.map(market => (
                <div key={market.id} className="space-y-1.5">
                  <div className="flex items-center justify-between px-0.5 text-[9px] font-black text-slate-500 uppercase">
                    <div className="flex items-center gap-1.5">
                      <span>{market.flag}</span> {market.name}
                    </div>
                    {marketStories[market.id].trim().length > 0 && <CheckCircle className="w-3 h-3 text-green-500" />}
                  </div>
                  <textarea 
                    value={marketStories[market.id]}
                    onChange={(e) => handleStoryChange(market.id, e.target.value)}
                    placeholder={`Paste story...`}
                    className="w-full h-28 p-3 text-xs font-medium bg-slate-50 border border-slate-100 rounded-xl outline-none focus:border-indigo-300 focus:bg-white transition-all resize-none"
                  />
                </div>
              ))}
            </div>
          </section>
        </div>

        {/* Middle Column */}
        <div className="lg:col-span-4">
          <div className="bg-white rounded-2xl shadow-xl border border-slate-200 h-[calc(100vh-8rem)] sticky top-20 flex flex-col">
            <div className="px-5 py-3 border-b border-slate-100 bg-slate-50/50">
              <h2 className="font-black text-slate-800 uppercase tracking-widest text-[10px]">Master Lead Editor</h2>
            </div>
            <textarea 
              className="flex-1 p-5 text-[14px] leading-relaxed outline-none resize-none font-medium text-slate-700 placeholder:text-slate-300 custom-scrollbar"
              placeholder="Paste Master Lead here..."
              value={masterLead}
              onChange={(e) => setMasterLead(e.target.value)}
            />
          </div>
        </div>

        {/* Right Column */}
        <div className="lg:col-span-4 space-y-4 h-[calc(100vh-8rem)] overflow-y-auto pr-1 custom-scrollbar sticky top-20">
          {MARKETS.map(market => (
            <div key={market.id} className={`bg-white rounded-2xl border shadow-sm overflow-hidden ${loading[market.id] ? 'opacity-60 scale-[0.98]' : 'border-slate-200'}`}>
              <div className="bg-slate-50 px-4 py-2 border-b border-slate-200 flex justify-between items-center font-black text-[9px] text-slate-600 uppercase">
                <div className="flex items-center gap-2"><span>{market.flag}</span> {market.name}</div>
                {results[market.id] && (
                  <button onClick={() => copyToClipboard(results[market.id])} className="p-1.5 hover:bg-white rounded-lg transition-all active:scale-90">
                    <Copy className="w-3.5 h-3.5 text-indigo-400" />
                  </button>
                )}
              </div>
              <div className="p-4 min-h-[100px]">
                {loading[market.id] ? (
                  <div className="space-y-3 animate-pulse">
                    <div className="h-2 bg-slate-100 rounded-full w-full"></div>
                    <div className="h-2 bg-slate-100 rounded-full w-[90%]"></div>
                  </div>
                ) : results[market.id] ? (
                  <div className="text-[13px] leading-relaxed text-slate-700 whitespace-pre-wrap font-medium">{results[market.id]}</div>
                ) : (
                  <div className="flex flex-col items-center justify-center py-6 opacity-20"><MapPin size={20} /></div>
                )}
              </div>
            </div>
          ))}
        </div>
      </main>

      {/* Popups */}
      {error && (
        <div className="fixed bottom-6 left-1/2 -translate-x-1/2 w-[90%] max-w-md bg-red-600 text-white p-4 rounded-xl shadow-2xl z-50 flex items-center justify-between font-bold text-xs">
          <div className="flex items-center gap-3"><AlertCircle size={18} /> {error}</div>
          <button onClick={() => setError(null)}>✕</button>
        </div>
      )}

      {successMsg && (
        <div className="fixed bottom-6 left-1/2 -translate-x-1/2 bg-green-500 text-white px-5 py-2.5 rounded-full shadow-2xl z-50 flex items-center gap-2 font-bold text-xs">
          <CheckCircle size={14} /> {successMsg}
        </div>
      )}

      <style dangerouslySetInnerHTML={{ __html: `
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #E2E8F0; border-radius: 10px; }
      `}} />
    </div>
  );
};

export default App;
